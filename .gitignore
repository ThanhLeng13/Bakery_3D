# ===========================================
# Bakery 3D - Root .gitignore
# ===========================================

# ---- 🔐 SECRETS & ENVIRONMENT VARIABLES (NEVER commit these!) ----
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local
# Keep example files (no real keys)
!**/.env.example
!**/.env.local.example

# ---- 🐍 Backend (Python / FastAPI) ----
backend/venv/
backend/.venv/
backend/env/
backend/__pycache__/
backend/**/__pycache__/
**/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/*.so
backend/*.egg-info/
backend/dist/
backend/build/
backend/.eggs/
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
.coverage
*.pyc
*.pyo

# ---- ⚛️ Frontend (Next.js) ----
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/.pnp
frontend/.pnp.js
frontend/.yarn/install-state.gz
frontend/coverage/
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
# Keep package-lock for reproducible installs
# !frontend/package-lock.json

# ---- 🐳 Docker ----
docker-compose.override.yml

# ---- ☁️ Supabase ----
supabase/.branches
supabase/.temp

# ---- 🛠 IDE & Editor ----
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# ---- 💻 OS Files ----
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
._*

# ---- 📋 Logs ----
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- ⏱️ Runtime / Temp / Cache ----
tmp_*/
.browser_profile/
.last_port
.pytest_cache/
.codex-docx-work/
*.tmp
*.temp

# ---- 📄 Local Documents & Reports (not for repo) ----
*.docx
*.pdf
docs/
image/

# ---- 🔧 Dev / Generation Tools ----
tools/
HUONG_DAN_CHAY_CODE.txt
seed.ps1
start.ps1
stop.ps1

# ---- 🤖 AI & Automation Tools ----
.kiro/
.qodo/
.gemini/
